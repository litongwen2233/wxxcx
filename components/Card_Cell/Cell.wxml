<!--components/Card_Cell/Cell.wxml-->
<view class="cell-voltage-container">
  <!-- 标题 -->
  <view class="title">{{title}}</view>
  <!-- 单体电压网格 -->
  <view class="cell-grid">
    <view 
      wx:for="{{cellData}}" 
      wx:key="index" 
      class="cell-item"
    >
      <view class="cell-button">
        <view class="cell-index">单体{{item.index}}</view>
        <view class="cell-value">{{item.value}}{{unit}}</view>
      </view>
    </view>
  </view>
</view>