/* pages/data_overview/data_overview.wxss */
.container {
  padding: 20px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.connection-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  background-color: #ffebee;
  border-radius: 20px;
  margin-bottom: 16px;
  font-size: 13px;
  color: #f44336;
}

.connection-status.connected {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: #f44336;
  margin-right: 8px;
  animation: blink 1.5s infinite;
}

.connection-status.connected .status-dot {
  background-color: #4caf50;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.action-buttons {
  display: flex;
  gap: 16px;
  margin-bottom: 20px;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  border-radius: 16px;
  font-size: 16px;
  font-weight: 600;
  color: white;
  border: none;
  cursor: pointer;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.96);
}

.charge-btn {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
}

.discharge-btn {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.btn-icon {
  font-size: 20px;
  margin-right: 8px;
}

.progress-section {
  margin-bottom: 20px;
  padding: 16px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.main-data {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 20px;
}

.data-row {
  display: flex;
  gap: 12px;
}

.data-item {
  flex: 1;
  padding: 20px 12px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  text-align: center;
}

.data-item.primary {
  padding: 20px 8px;
}

.data-item.secondary {
  padding: 16px 8px;
}

.data-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.data-value {
  font-size: 24px;
  font-weight: bold;
  color: #333;
}

.data-item.primary .data-value {
  font-size: 28px;
  color: #2196F3;
}

.unit {
  font-size: 14px;
  color: #999;
  margin-left: 2px;
}

.status-normal {
  color: #4CAF50;
}

.status-warning {
  color: #FF9800;
}

.status-danger {
  color: #F44336;
}

.update-status {
  text-align: center;
  padding: 12px;
  background: white;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.update-text {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 4px;
}

.update-time {
  display: block;
  font-size: 11px;
  color: #999;
}