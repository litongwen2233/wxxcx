/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}
/* 页面整体样式 */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh; /* 占满整个视口高度 */
}
/* 中间内容区域：自动填充剩余空间，可滚动 */
.content-area {
  flex: 1; /* 占据剩余所有空间 */
  overflow-y: auto; /* 内容过多时可滚动 */
  padding: 20rpx;
  padding-bottom: 120rpx; /* 为底部固定按钮预留空间 */
}

/* 页面内容样式 */
.page-content {
  min-height: 100%;
}

/* 顶部吸顶标题栏 */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}
.btn.listdata{
  flex: 1;
  width: 28%;
  height: 280rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  border: 1rpx solid #ddd;
  transition: all 0.3s;
}
.device_list{

}
.cell-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr; /* 每行4列 */

  gap: 10rpx;
  padding: 10rpx;
}

.cell-item {
  display: flex;
  width: 100%;

}
.btn.listdata.cell{
  flex: 1;
  width: 28%;
  height: 180rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  border: 1rpx solid #ddd;
  transition: all 0.3s;
}