/* pages/ble_scan/ble_scan.wxss */
.container {
  padding: 20px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.scan-header {
  text-align: center;
  margin-bottom: 20px;
  padding: 20px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.scan-icon {
  width: 80px;
  height: 80px;
  margin-bottom: 12px;
}

.scan-title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.device-count {
  font-size: 14px;
  color: #999;
}

.scan-control {
  margin-bottom: 20px;
}

.scan-btn {
  width: 100%;
  padding: 14px;
  background-color: #2196F3;
  color: white;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  transition: all 0.3s;
}

.scan-btn.scanning {
  background-color: #ff9800;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.8; }
  100% { opacity: 1; }
}

.device-list {
  height: calc(100vh - 300px);
}

.device-item {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  cursor: pointer;
  transition: transform 0.2s;
}

.device-item-hover {
  transform: scale(0.98);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
}

.device-name {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.name-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.connect-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 10px;
  background-color: #ffebee;
  color: #f44336;
}

.connect-status.connected {
  background-color: #e8f5e9;
  color: #4caf50;
}

.device-details {
  display: flex;
  gap: 16px;
  margin-bottom: 6px;
}

.detail-item {
  font-size: 12px;
  color: #666;
}

.device-uuid {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.uuid-text {
  font-size: 11px;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-count {
  font-size: 11px;
  color: #999;
  margin-left: 8px;
}

.loading {
  text-align: center;
  color: #999;
  padding: 40px;
}